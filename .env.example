# คัดลอกไฟล์นี้เป็น .env.local แล้วกรอกค่าจริงจาก Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ใช้เฉพาะฝั่ง server สำหรับสร้างสมาชิกผ่านหน้า Settings > เพิ่มสมาชิก
# ห้ามใส่ NEXT_PUBLIC_ และห้าม commit ค่าจริง
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ใช้เฉพาะตอนรัน `npm run db:types` เพื่อ gen TypeScript types จาก schema จริง
SUPABASE_PROJECT_ID=xxxxxxxxxxxx

# ระบบ Backup & Restore ไปยัง Google Drive ส่วนตัว (server only)
# สร้าง OAuth 2.0 Web application ใน Google Cloud และเปิด Google Drive API
GOOGLE_DRIVE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=xxxxxxxx
# เว้นว่างได้ใน local; production แนะนำกำหนด URL callback ให้ตรงกับ Google Cloud
GOOGLE_DRIVE_REDIRECT_URI=https://example.com/api/settings/backups/google/callback
# ค่าลับอย่างน้อย 24 ตัวอักษร ใช้เข้ารหัส OAuth token และไฟล์ .oilbackup
BACKUP_MASTER_KEY=replace-with-a-long-random-secret
BACKUP_MAX_SIZE_MB=250
# ปิด Restore ไว้เป็นค่าเริ่มต้น เปิดเฉพาะเมื่อพร้อมทดสอบแผนกู้คืน
BACKUP_RESTORE_ENABLED=false
# Vercel ส่งค่านี้ใน Authorization header ของ Cron Job
CRON_SECRET=replace-with-a-long-random-secret
