# คัดลอกไฟล์นี้เป็น .env.local แล้วกรอกค่าจริงจาก Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ใช้เฉพาะฝั่ง server สำหรับสร้างสมาชิกผ่านหน้า Settings > เพิ่มสมาชิก
# ห้ามใส่ NEXT_PUBLIC_ และห้าม commit ค่าจริง
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ใช้เฉพาะตอนรัน `npm run db:types` เพื่อ gen TypeScript types จาก schema จริง
SUPABASE_PROJECT_ID=xxxxxxxxxxxx
